<Window x:Class="PingGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ping Guard"
        Icon="pinggua.ico"
        Width="380" Height="560"
        MinWidth="380" MinHeight="560"
        MaxWidth="380" MaxHeight="560"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True">

  <Window.Resources>
    <Style x:Key="SettingInput" TargetType="TextBox">
      <Setter Property="Background"       Value="#0f0f14"/>
      <Setter Property="Foreground"       Value="#c0c0cc"/>
      <Setter Property="BorderBrush"      Value="#2a2a35"/>
      <Setter Property="BorderThickness"  Value="1"/>
      <Setter Property="Padding"          Value="8,5"/>
      <Setter Property="FontFamily"       Value="Consolas"/>
      <Setter Property="FontSize"         Value="11"/>
      <Setter Property="CaretBrush"       Value="#00f0ff"/>
      <Setter Property="SelectionBrush"   Value="#1a3a4a"/>
      <Style.Triggers>
        <Trigger Property="IsFocused" Value="True">
          <Setter Property="BorderBrush" Value="#00f0ff"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="IconBtn" TargetType="Button">
      <Setter Property="Width"           Value="28"/>
      <Setter Property="Height"          Value="28"/>
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"      Value="#555565"/>
      <Setter Property="FontFamily"      Value="Consolas"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    CornerRadius="5" Padding="0">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#18181f"/>
                <Setter Property="Foreground" Value="#c0c0cc"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#22222e"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ToggleStyle" TargetType="CheckBox">
      <Setter Property="Foreground"  Value="#666674"/>
      <Setter Property="FontFamily"  Value="Consolas"/>
      <Setter Property="FontSize"    Value="10"/>
      <Setter Property="Cursor"      Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Border x:Name="track" Width="28" Height="15" CornerRadius="8"
                      Background="#1a1a22" BorderBrush="#2a2a35" BorderThickness="1" Margin="0,0,6,0">
                <Border x:Name="thumb" Width="11" Height="11" CornerRadius="6"
                        Background="#44444e" Margin="1,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
              </Border>
              <ContentPresenter VerticalAlignment="Center"/>
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="track" Property="Background"   Value="#0a2a1a"/>
                <Setter TargetName="track" Property="BorderBrush"  Value="#4ade80"/>
                <Setter TargetName="thumb" Property="Background"   Value="#4ade80"/>
                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                <Setter TargetName="thumb" Property="Margin"       Value="0,0,1,0"/>
                <Setter Property="Foreground" Value="#8a8a9a"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#9a9aaa"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <!-- Outer shell with rounded corners -->
  <Border Background="#060608" CornerRadius="12"
          BorderBrush="#1e1e28" BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="6" Opacity=".6" Direction="270"/>
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>    <!-- title bar -->
        <RowDefinition Height="*"/>     <!-- content -->
        <RowDefinition Height="Auto"/>  <!-- settings -->
      </Grid.RowDefinitions>

      <!-- ── TITLE BAR ── -->
      <Border Grid.Row="0" CornerRadius="12,12,0,0"
              Background="#0a0a0e" BorderBrush="#1e1e28" BorderThickness="0,0,0,1"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid Margin="14,0,8,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Status dot + name -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" IsHitTestVisible="False">
            <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="#44444e" Margin="0,0,8,0"/>
            <TextBlock Text="PING GUARD"
                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                       Foreground="#9a9aaa"/>
          </StackPanel>

          <!-- Window buttons -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="PinBtn" Style="{StaticResource IconBtn}"
                    ToolTip="Always on top" Click="PinBtn_Click">
              <TextBlock Text="📌" FontSize="10" IsHitTestVisible="False"/>
            </Button>
            <Button Style="{StaticResource IconBtn}" Click="MinimizeBtn_Click">
              <TextBlock Text="─" FontFamily="Consolas" FontSize="11"/>
            </Button>
            <Button Style="{StaticResource IconBtn}" Click="CloseBtn_Click">
              <TextBlock Text="✕" FontFamily="Consolas" FontSize="11"/>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ── MAIN CONTENT ── -->
      <StackPanel Grid.Row="1" Margin="0,0,0,0">

        <!-- BIG PING NUMBER -->
        <Grid Height="100" Margin="0,0,0,0">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="PingValue" Text="—"
                       FontFamily="Consolas" FontSize="64" FontWeight="Bold"
                       Foreground="#4ade80" HorizontalAlignment="Center"
                       LineHeight="64"/>
            <TextBlock x:Name="PingUnit" Text="ms"
                       FontFamily="Consolas" FontSize="11" Foreground="#444454"
                       HorizontalAlignment="Center" Margin="0,-4,0,0"/>
          </StackPanel>
        </Grid>

        <!-- Target + status row -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
          <TextBlock x:Name="TargetLabel" Text="TARGET · 1.1.1.1"
                     FontFamily="Consolas" FontSize="9" Foreground="#333344"
                     HorizontalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
            <Ellipse x:Name="OnlineDot" Width="6" Height="6" Fill="#44444e" Margin="0,0,5,0"/>
            <TextBlock x:Name="StatusLabel" Text="AGUARDANDO"
                       FontFamily="Consolas" FontSize="9" Foreground="#444454"/>
          </StackPanel>
        </StackPanel>

        <!-- Secondary target rows -->
        <Border x:Name="SecRow1" Visibility="Collapsed"
                Margin="16,0,16,4" Padding="10,5"
                Background="#08080c" CornerRadius="6"
                BorderBrush="#18181f" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="68"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SecLabel1" Text="HOST 2"
                       FontFamily="Consolas" FontSize="9" Foreground="#333344"
                       VerticalAlignment="Center"/>
            <Ellipse x:Name="SecDot1" Grid.Column="1"
                     Width="6" Height="6" Fill="#44444e" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="SecPing1" Grid.Column="2" Text="—"
                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                       Foreground="#c0c0cc" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <Border x:Name="SecRow2" Visibility="Collapsed"
                Margin="16,0,16,4" Padding="10,5"
                Background="#08080c" CornerRadius="6"
                BorderBrush="#18181f" BorderThickness="1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="68"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SecLabel2" Text="HOST 3"
                       FontFamily="Consolas" FontSize="9" Foreground="#333344"
                       VerticalAlignment="Center"/>
            <Ellipse x:Name="SecDot2" Grid.Column="1"
                     Width="6" Height="6" Fill="#44444e" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="SecPing2" Grid.Column="2" Text="—"
                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                       Foreground="#c0c0cc" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <!-- SPARKLINE -->
        <Border Margin="16,0,16,0" Height="82"
                Background="#0a0a0e" CornerRadius="8"
                BorderBrush="#1a1a22" BorderThickness="1">
          <Canvas x:Name="SparkCanvas" Margin="8,6,8,6" ClipToBounds="True"/>
        </Border>
        <TextBlock Text="ÚLTIMOS 2 MINUTOS"
                   FontFamily="Consolas" FontSize="8" Foreground="#222230"
                   HorizontalAlignment="Right" Margin="0,4,18,0"/>

        <!-- STATS ROW -->
        <Border Margin="16,10,16,0"
                Background="#0a0a0e" CornerRadius="8"
                BorderBrush="#1a1a22" BorderThickness="1" Padding="0,10">
          <UniformGrid Columns="5">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="StatAvg"    Text="—"   FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#c0c0cc" HorizontalAlignment="Center"/>
              <TextBlock Text="AVG"                      FontFamily="Consolas" FontSize="8"  Foreground="#2a2a38" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="StatP95"    Text="—"   FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#c0c0cc" HorizontalAlignment="Center"/>
              <TextBlock Text="P95"                      FontFamily="Consolas" FontSize="8"  Foreground="#2a2a38" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="StatJitter" Text="—"   FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#c0c0cc" HorizontalAlignment="Center"/>
              <TextBlock Text="JITTER"                   FontFamily="Consolas" FontSize="8"  Foreground="#2a2a38" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="StatLoss"   Text="—"   FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#c0c0cc" HorizontalAlignment="Center"/>
              <TextBlock Text="LOSS"                     FontFamily="Consolas" FontSize="8"  Foreground="#2a2a38" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center">
              <TextBlock x:Name="StatUptime" Text="—"   FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#c0c0cc" HorizontalAlignment="Center"/>
              <TextBlock Text="UPTIME"                   FontFamily="Consolas" FontSize="8"  Foreground="#2a2a38" HorizontalAlignment="Center" Margin="0,1,0,0"/>
            </StackPanel>
          </UniformGrid>
        </Border>

      </StackPanel>

      <!-- ── SETTINGS PANEL ── -->
      <Border Grid.Row="2"
              Background="#0a0a0e" CornerRadius="0,0,12,12"
              BorderBrush="#1e1e28" BorderThickness="0,1,0,0"
              Padding="16,12,16,14">
        <StackPanel>

          <!-- Host inputs + Alert -->
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="92"/>
            </Grid.ColumnDefinitions>

            <!-- Hosts column -->
            <StackPanel Grid.Column="0">
              <TextBlock Text="HOSTS" FontFamily="Consolas" FontSize="8" Foreground="#333344" Margin="0,0,0,3"/>
              <TextBox x:Name="TargetInput" Style="{StaticResource SettingInput}"
                       LostFocus="TargetInput_LostFocus"
                       KeyDown="TargetInput_KeyDown"
                       Margin="0,0,0,3"/>
              <TextBox x:Name="ExtraInput1" Style="{StaticResource SettingInput}"
                       LostFocus="ExtraInput1_LostFocus"
                       KeyDown="ExtraInput1_KeyDown"
                       Margin="0,0,0,3"/>
              <TextBox x:Name="ExtraInput2" Style="{StaticResource SettingInput}"
                       LostFocus="ExtraInput2_LostFocus"
                       KeyDown="ExtraInput2_KeyDown"/>
            </StackPanel>

            <!-- Alert column -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top">
              <TextBlock Text="ALERTA (MS)" FontFamily="Consolas" FontSize="8" Foreground="#333344" Margin="0,0,0,3"/>
              <TextBox x:Name="AlertInput" Style="{StaticResource SettingInput}"
                       LostFocus="AlertInput_LostFocus"
                       KeyDown="AlertInput_KeyDown"/>
            </StackPanel>
          </Grid>

          <!-- Toggles row -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="AlwaysOnTopCheck" Grid.Column="0"
                      Content="On top"
                      Style="{StaticResource ToggleStyle}"
                      Checked="AlwaysOnTop_Changed" Unchecked="AlwaysOnTop_Changed"/>

            <CheckBox x:Name="AutoStartCheck" Grid.Column="1"
                      Content="Autostart"
                      Style="{StaticResource ToggleStyle}"
                      Checked="AutoStart_Changed" Unchecked="AutoStart_Changed"/>

            <CheckBox x:Name="SoundCheck" Grid.Column="2"
                      Content="Sonido"
                      Style="{StaticResource ToggleStyle}"
                      Checked="Sound_Changed" Unchecked="Sound_Changed"/>

            <Button Grid.Column="3"
                    Click="CopyStats_Click"
                    Style="{StaticResource IconBtn}"
                    ToolTip="Copiar estadísticas">
              <TextBlock Text="📋" FontSize="11"/>
            </Button>
          </Grid>

          <!-- Update badge (hidden until update available) -->
          <Border x:Name="UpdateBadge" Visibility="Collapsed"
                  Background="#0a1a10" BorderBrush="#4ade80" BorderThickness="1"
                  CornerRadius="6" Padding="10,7" Margin="0,10,0,0"
                  Cursor="Hand" MouseLeftButtonDown="UpdateBadge_Click">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="UpdateBadgeText" Text=""
                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                           Foreground="#4ade80"/>
                <TextBlock Text="Click para actualizar"
                           FontFamily="Consolas" FontSize="8" Foreground="#2a6640"
                           Margin="0,1,0,0"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="↑" FontFamily="Consolas" FontSize="16"
                         Foreground="#4ade80" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
          </Border>

        </StackPanel>
      </Border>

    </Grid>
  </Border>
</Window>
